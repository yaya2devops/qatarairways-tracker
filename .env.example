# Email
EMAIL_HOST=smtp.yourserver.com
EMAIL_PORT=587
EMAIL_USER=you@yourdomain.com
EMAIL_PASS=your_password
EMAIL_FROM=noreply@yourdomain.com
EMAIL_TO=you@yourdomain.com,someone@else.com   # comma-separated for multiple recipients

# Port for the management HTTP API
PORT=3000

# No need to set cookies manually — they are captured automatically via Playwright on startup
