# Email (Gmail example — use an App Password, not your real password)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=you@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=noreply@yourdomain.com   # authorized sender on your SMTP server
EMAIL_TO=you@gmail.com
EMAIL_FROM=as@asda.sd
# Polling interval — edit tracker-scheduler.service.ts to change the cron expression
# Default: every 10 minutes

# Port for the management HTTP API
PORT=3000

# No need to set cookies manually — they are captured automatically via Playwright on startup
